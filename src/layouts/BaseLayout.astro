---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'We make it work. | FrontierWorks',
  description = 'AI 기반 교육 솔루션 · 워크플로우 자동화. 복잡한 인공지능 기술을 현장에서 바로 사용할 수 있는 실체로 구현합니다.',
} = Astro.props;

const siteUrl = Astro.site?.toString().replace(/\/$/, '') ?? '';
---

<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{title}</title>
    <meta name="description" content={description}>
    <meta name="robots" content="index, follow">
    <meta name="author" content="FrontierWorks">
    <meta name="theme-color" content="#030712">

    <link rel="icon" href="/favicon.svg" type="image/svg+xml">

    <meta property="og:type" content="website">
    <meta property="og:title" content={title}>
    <meta property="og:description" content="AI 기반 교육 솔루션 · 워크플로우 자동화.">
    <meta property="og:image" content={`${siteUrl}/og-image.png`}>
    <meta property="og:url" content={siteUrl}>
    <meta property="og:locale" content="ko_KR">

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;700;900&display=swap" rel="stylesheet">
    <link rel="stylesheet" as="style" crossorigin
        href="https://cdn.jsdelivr.net/gh/orioncactus/pretendard@v1.3.9/dist/web/static/pretendard.min.css" />
</head>
<body>
    <slot />
</body>
</html>

<style is:global>
    @import '../styles/global.css';
</style>
