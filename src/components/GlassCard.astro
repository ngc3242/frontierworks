---
interface Props {
  icon: 'education' | 'management' | 'business';
  title: string;
  badge: string;
  description: string;
}

const { icon, title, badge, description } = Astro.props;

const icons = {
  education: `<path d="M22 10v6M2 10l10-5 10 5-10 5z" /><path d="M6 12v5c3 3 9 3 12 0v-5" />`,
  management: `<rect x="3" y="3" width="18" height="18" rx="2" ry="2" /><line x1="3" y1="9" x2="21" y2="9" /><line x1="9" y1="21" x2="9" y2="9" />`,
  business: `<path d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6" />`,
};
---

<div class="glass-card reveal-up">
    <div class="card-icon">
        <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="url(#blue-gradient)"
            stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <Fragment set:html={icons[icon]} />
        </svg>
    </div>
    <h3>{title}</h3>
    <div class="card-badge">{badge}</div>
    <p>{description}</p>
    <div class="card-glow"></div>
</div>

<style>
    .glass-card {
        background: var(--color-surface);
        border: 1px solid var(--color-border);
        border-radius: 24px;
        padding: 2.5rem 2rem;
        backdrop-filter: blur(16px);
        -webkit-backdrop-filter: blur(16px);
        position: relative;
        overflow: hidden;
        transition: transform 0.3s ease, background 0.3s ease;
        display: flex;
        flex-direction: column;
    }

    .glass-card:hover {
        transform: translateY(-10px);
        background: var(--color-surface-hover);
    }

    .card-glow {
        position: absolute;
        width: 150px;
        height: 150px;
        background: var(--color-brand-works);
        filter: blur(80px);
        border-radius: 50%;
        top: -50px;
        right: -50px;
        opacity: 0;
        transition: opacity 0.5s ease;
        pointer-events: none;
    }

    .glass-card:hover .card-glow {
        opacity: 0.3;
    }

    .card-icon {
        margin-bottom: 1.5rem;
        display: flex;
        align-items: center;
        justify-content: center;
        width: 64px;
        height: 64px;
        border-radius: 16px;
        background: rgba(255, 255, 255, 0.05);
        border: 1px solid rgba(255, 255, 255, 0.1);
    }

    h3 {
        font-size: 1.5rem;
        margin-bottom: 0.5rem;
    }

    .card-badge {
        display: inline-block;
        background: rgba(59, 130, 246, 0.15);
        color: var(--color-accent-1);
        padding: 0.3rem 0.8rem;
        border-radius: 12px;
        font-size: 0.8rem;
        font-weight: 600;
        margin-bottom: 1.5rem;
        align-self: flex-start;
        border: 1px solid rgba(59, 130, 246, 0.3);
    }

    p {
        color: var(--color-text-secondary);
        font-size: 1.05rem;
        line-height: 1.6;
    }
</style>
