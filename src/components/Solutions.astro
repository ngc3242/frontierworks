---
import GlassCard from './GlassCard.astro';

const cards = [
  {
    icon: 'education' as const,
    title: 'It Works for Teachers',
    badge: 'AutoQM / SARA',
    description: '"상상만 하던 AI 문제 제작과 자동 답변, 프론티어웍스가 현장의 언어로 구현했습니다."',
  },
  {
    icon: 'management' as const,
    title: 'It Works for Management',
    badge: 'FrontierEdu',
    description: '"복잡한 학원 운영 시스템을 가장 직관적이고 효율적인 자동화 프로세스로 완성합니다."',
  },
  {
    icon: 'business' as const,
    title: 'It Works for Your Business',
    badge: 'Beomjaka / Custom',
    description: '"고객의 비즈니스 모델이 무엇이든, 우리는 그것이 기술적으로 완벽히 돌아가게 만듭니다."',
  },
];
---

<section class="solutions" id="solutions">
    <div class="section-header reveal-up">
        <h2 class="section-title">The 3 <span class="highlight">'Works'</span></h2>
        <p class="section-subtitle">"We make it work"의 의미를 세 가지 핵심 가치로 증명합니다.</p>
    </div>

    <div class="cards-container">
        <svg width="0" height="0">
            <linearGradient id="blue-gradient" x1="100%" y1="100%" x2="0%" y2="0%">
                <stop stop-color="#4facfe" offset="0%" />
                <stop stop-color="#00f2fe" offset="100%" />
            </linearGradient>
        </svg>
        {cards.map((card, i) => (
            <div class={`card-wrapper delay-${i + 1}`}>
                <GlassCard {...card} />
            </div>
        ))}
    </div>
</section>

<style>
    .solutions {
        padding: 8rem 2rem;
        max-width: 1200px;
        margin: 0 auto;
        position: relative;
        z-index: 10;
    }

    .section-header {
        text-align: center;
        margin-bottom: 4rem;
    }

    .section-title {
        font-size: 3rem;
        font-weight: 700;
        margin-bottom: 1rem;
    }

    .section-subtitle {
        font-size: 1.2rem;
        color: var(--color-text-secondary);
    }

    .cards-container {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
        gap: 2rem;
    }
</style>
