---
---

<footer>
    <div class="footer-content">
        <div class="footer-brand">
            <div class="logo">
                <span class="logo-frontier">Frontier</span><span class="logo-works">Works</span>
            </div>
            <p>AI-powered Education & Workflow Automation Specialist</p>
        </div>
        <div class="footer-links">
            <div class="link-group">
                <h4>Company</h4>
                <a href="#about">About Us</a>
                <a href="#careers">Careers</a>
                <a href="#contact">Contact</a>
            </div>
            <div class="link-group">
                <h4>Solutions</h4>
                <a href="#autoqm">AutoQM</a>
                <a href="#frontieredu">FrontierEdu</a>
                <a href="#beomjaka">Beomjaka</a>
            </div>
        </div>
    </div>
    <div class="footer-bottom">
        <p>&copy; 2026 FrontierWorks Inc. All rights reserved.</p>
    </div>
</footer>

<style>
    footer {
        border-top: 1px solid var(--color-border);
        padding: 4rem 2rem 2rem;
        background: #000;
        position: relative;
        z-index: 10;
    }

    .footer-content {
        max-width: 1200px;
        margin: 0 auto;
        display: flex;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 3rem;
        margin-bottom: 3rem;
    }

    .footer-brand p {
        color: var(--color-text-secondary);
        margin-top: 1rem;
        font-size: 0.9rem;
    }

    .footer-links {
        display: flex;
        gap: 4rem;
    }

    .link-group h4 {
        margin-bottom: 1.5rem;
        font-size: 1.1rem;
    }

    .link-group a {
        display: block;
        color: var(--color-text-secondary);
        margin-bottom: 0.8rem;
        font-size: 0.95rem;
        transition: color 0.2s;
    }

    .link-group a:hover {
        color: #fff;
    }

    .footer-bottom {
        max-width: 1200px;
        margin: 0 auto;
        text-align: center;
        color: var(--color-text-secondary);
        font-size: 0.85rem;
        border-top: 1px solid rgba(255, 255, 255, 0.05);
        padding-top: 2rem;
    }

    @media (max-width: 768px) {
        .footer-links {
            flex-wrap: wrap;
            gap: 2rem;
        }
    }
</style>
